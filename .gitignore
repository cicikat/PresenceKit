# runtime data — see blacklist.example.yaml and relations.example.yaml for structure
data/
logs/
# 角色卡（实际角色文件含隐私内容不提交；空白模板见 examples/character_template.json）
characters/*.json
characters/*.txt
!characters/default.json
!characters/default_author_notes.json
# 私人梦境预设、私密世界观、私密现实层 —— ignore-but-authored
characters/dream_presets/
characters/dream_worlds/
characters/reality/
# content/characters/ 内 ignore-but-authored 私人本体（.example.yaml 仍 track）
# 以下路径是 activity_pool / yexuan_traits / author_notes_pool accessor 的新 primary 目标
content/characters/*/*.yaml
content/characters/*/*_author_notes.json
!content/characters/**/*.example.yaml
!content/characters/**/*.example.json
# content/ (authored static) と defaults/ (seed) は track 対象 — ignore 除外不要
config.yaml
.claude/
assets/stickers/*
!assets/stickers/.gitkeep
__pycache__/
*.pyc
*.log
.env
.env.*
DESIGN.md
tests/test_record.md
tests/eval_set.json
content/characters/yexuan/voice/
# test artifacts — generated by pytest, ACL-locked, never commit
data/test_sandbox/
character/
content/