# runtime data — see blacklist.example.yaml and relations.example.yaml for structure
data/
logs/
# 角色卡（实际角色文件含隐私内容不提交；空白模板见 examples/character_template.json）
characters/*.json
characters/*.txt
!characters/default.json
!characters/default_author_notes.json
# 私人梦境预设、私密世界观、私密现实层 —— ignore-but-authored
characters/dream_presets/
characters/dream_worlds/
characters/reality/
# content/characters/ 内 ignore-but-authored 私人本体（.example.yaml 仍 track）
# 以下路径是 activity_pool / yexuan_traits / author_notes_pool accessor 的新 primary 目标
content/characters/*/*.yaml
content/characters/*/*_author_notes.json
!content/characters/**/*.example.yaml
!content/characters/**/*.example.json
# 公开默认角色的配套资产：真实 track，不是 .example 模板
!content/characters/default/traits.yaml
!content/characters/default/activity_pool.yaml
# yexuan 私人信件示范库 / 读书笔记（不属于上面的 *.yaml / *_author_notes.json 模式）
content/characters/yexuan/letter_samples/
content/characters/yexuan/knowledge/
# content/ (authored static) と defaults/ (seed) は track 対象 — ignore 除外不要
config.yaml
# 本地密码本（Brief 22）—— 明文凭据，永远不要提交；模板见 secrets.example.yaml
secrets.local.yaml
assets/stickers/*
!assets/stickers/.gitkeep
__pycache__/
*.pyc
*.log
.env
.env.*
.tmp
DESIGN.md
tests/test_record.md
tests/eval_set.json
# v0.1 开源筹备用的内部排查/施工清单，引用了真实 QQ 号等隐私信息，不进版本库
docs/opensource-v0.1-checklist.md
docs/archive/opensource-v0.1-checklist.md
content/characters/yexuan/voice/
# test artifacts — generated by pytest, ACL-locked, never commit
data/test_sandbox/
character/
# 注意：此处不可加回顶层 "content/" 整体忽略——与上方 content/characters/ 细粒度规则矛盾，
# 会导致 content/（authored 静态资产，如 default 角色的 activity_pool/traits/letter_samples）
# 整体脱离版本库，是 v0.1 开源前排查到的“fresh clone 缺开箱资产”根因之一。
# firmware build artifacts / private WiFi+backend credentials
firmware/**/.pio/
firmware/**/build/
firmware/presence-device/include/secrets.h
# Claude Code local edit-history cache — not authored content, machine/session-specific
.claude/.cache/
# 含个人机器路径与用户名的本地权限列表，非团队共享配置
.claude/settings.json